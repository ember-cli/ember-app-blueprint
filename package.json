{
  "name": "@ember/app-blueprint",
  "version": "7.0.1",
  "description": "Blueprint for next generation of Ember apps",
  "keywords": [
    "ember-blueprint"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:ember-cli/ember-app-blueprint.git"
  },
  "license": "MIT",
  "author": "",
  "main": "index.js",
  "scripts": {
    "lint": "concurrently 'pnpm:lint:*(!fix)'",
    "lint:fix": "pnpm lint:eslint && pnpm format",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier . --check",
    "format": "prettier . --write",
    "test": "vitest",
    "new:app": "pnpm dlx ember-cli@latest new my-app --blueprint ."
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "ejs": "^3.1.10",
    "ember-cli-string-utils": "^1.1.0",
    "lodash": "^4.18.1",
    "sort-package-json": "^3.6.1",
    "walk-sync": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.2.1",
    "ember-cli": "^7.0.0",
    "eslint": "9.x",
    "eslint-config-prettier": "^9.1.2",
    "execa": "^9.6.1",
    "fixturify": "^3.0.0",
    "globals": "^15.15.0",
    "jsonc-parser": "^3.3.1",
    "prettier": "^3.8.3",
    "prettier-plugin-ember-template-tag": "^2.1.5",
    "release-plan": "^0.17.4",
    "strip-ansi": "^7.2.0",
    "tmp-promise": "^3.0.3",
    "vitest": "^4.1.5",
    "vitest-matrix": "^0.2.0"
  },
  "packageManager": "pnpm@10.20.0"
}
